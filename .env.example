# --- Core ---
PORT=3000

# --- Tier 1: leave both false, no other vars needed ---
DB_ENABLED=true
REDIS_ENABLED=true

# --- Tier 2: set DB_ENABLED=true and fill these in ---
PGHOST=database
PGPORT=5432
PGDATABASE=shortener
PGUSER=postgres
PGPASSWORD=postgres
# Alternative to PGPASSWORD above, for Docker secrets:
# PGPASSWORD_FILE=/run/secrets/pg_password

# --- Tier 3: set REDIS_ENABLED=true and fill these in ---
# Compose service name (preferred DNS name on the Docker network)
REDIS_HOST=cache_db
REDIS_PORT=6379
# Optional Redis auth (set this if your Redis instance requires a password)
REDIS_PASSWORD=redis_pass